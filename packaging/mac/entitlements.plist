<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for signed/notarized Earshot builds.
     Unused by ad-hoc (unsigned) builds. -->
<plist version="1.0">
<dict>
    <!-- Microphone capture -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- PyInstaller bundles mix Python wheels signed by many teams -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- CPython + cffi need writable+executable pages under hardened runtime -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
